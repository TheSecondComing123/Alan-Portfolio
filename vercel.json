{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "content/**",
                    "public/**",
                    "node_modules/lenis/dist/**",
                    "views/**"
                ]
            }
        }
    ],
    "routes": [{ "src": "/(.*)", "dest": "/server.js" }]
}
