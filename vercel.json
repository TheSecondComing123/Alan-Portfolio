{
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "content/**",
                    "css/**",
                    "images/**",
                    "js/**",
                    "views/**",
                    "robots.txt"
                ]
            }
        }
    ],
    "routes": [{ "src": "/(.*)", "dest": "/server.js" }]
}
