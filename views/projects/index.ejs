<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Projects | Alan Bagel</title>
  <meta
    name="description"
    content="Projects by Alan Bagel - games, compilers, terminal apps, and web platforms across Rust, Scala, TypeScript, Python, and C."
  />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1b211b" />
  <link rel="canonical" href="https://alanthebagel.com/projects" />
  <meta property="og:type" content="website" />
  <meta property="og:title" content="Projects | Alan Bagel" />
  <meta
    property="og:description"
    content="Projects by Alan Bagel - games, compilers, terminal apps, and web platforms across Rust, Scala, TypeScript, Python, and C."
  />
  <meta property="og:locale" content="en_US" />
  <meta property="og:url" content="https://alanthebagel.com/projects" />

  <script type="application/ld+json"<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://alanthebagel.com/" },
      { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://alanthebagel.com/projects" }
    ]
  }
  </script>

  <link rel="stylesheet" href="/css/site.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="/css/vendor/lenis.css?v=<%= assetVersion %>" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
