<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Alan Bagel | Student Programmer & Code Golfer</title>
  <meta
    name="description"
    content="Portfolio of Alan Bagel - student programmer from the east coast interested in competitive programming, frontend development, and game development."
  />
  <meta
    name="keywords"
    content="programming, portfolio, competitive programming, frontend development, game development"
  />
  <meta name="author" content="Alan Bagel" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1b211b" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Alan Bagel | Student Programmer & Code Golfer" />
  <meta
    property="og:description"
    content="Portfolio of Alan Bagel - student programmer from the east coast interested in competitive programming, frontend development, and game development."
  />
  <meta property="og:locale" content="en_US" />

  <script type="application/ld+json"<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alan Bagel",
      "description": "Student programmer from the east coast",
      "jobTitle": "Student Programmer",
      "email": "turkeysandwich179@outlook.com",
      "url": "https://alanthebagel.com",
      "sameAs": [
        "https://github.com/TheSecondComing123",
        "https://itch.io/profile/alandabagel"
      ]
    }
  </script>

  <link rel="stylesheet" href="/css/site.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="/css/vendor/lenis.css?v=<%= assetVersion %>" />
  <link rel="icon" type="image/png" href="/images/favicon.png" />
  <link rel="prefetch" href="/blog" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600&family=Manrope:wght@400;500;600;700&family=Sora:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </noscript>

  <noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@v2.17.0/devicon.min.css" />
  </noscript>
</head>
<body data-asset-version="<%= assetVersion %>">
  <main id="app" role="main" aria-label="Portfolio content">
    <%- include('./partials/home') %>
    <%- include('./partials/projects') %>
    <%- include('./partials/work') %>
    <%- include('./partials/technologies') %>
  </main>

  <nav role="navigation" aria-label="Main navigation">
    <button
      type="button"
      class="nav-button"
      data-section="home"
      aria-label="Home"
      aria-current="page"
      id="btn-home"
    ></button>
    <button type="button" class="nav-button" data-section="projects" aria-label="Projects" id="btn-projects"></button>
    <button type="button" class="nav-button" data-section="work" aria-label="Work" id="btn-work"></button>
    <button
      type="button"
      class="nav-button"
      data-section="technologies"
      aria-label="Key Technologies"
      id="btn-technologies"
    ></button>
  </nav>

  <footer class="site-footer" aria-label="Site footer">
    <p class="site-footer-line">&copy; <%= new Date().getFullYear() %> Alan Bagel. Keep calm and eat bagels.</p>
  </footer>

  <script src="/js/utils.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/index.js?v=<%= assetVersion %>" defer></script>
</body>
</html>
