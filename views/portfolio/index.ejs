<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Alan Bagel | Frontend & Systems Engineer</title>
  <meta
    name="description"
    content="Alan Bagel builds fast, high-signal software across frontend engineering, systems work, developer tools, and game-adjacent projects."
  />
  <meta
    name="keywords"
    content="Alan Bagel, frontend engineer, systems engineer, Rust, Svelte, TypeScript, portfolio, developer tools"
  />
  <meta name="author" content="Alan Bagel" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1b211b" />

  <meta property="og:type" content="website" />
  <meta property="og:title" content="Alan Bagel | Frontend & Systems Engineer" />
  <meta
    property="og:description"
    content="Fast software, thoughtful product work, and technical writing from Alan Bagel."
  />
  <meta property="og:image" content="https://alanthebagel.com/images/og.png" />
  <meta property="og:locale" content="en_US" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content="https://alanthebagel.com/images/og.png" />

  <script type="application/ld+json"<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
    {
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Alan Bagel",
      "description": "Frontend and systems engineer focused on performance-heavy apps, developer tools, and product-minded UI work.",
      "jobTitle": "Frontend & Systems Engineer",
      "email": "<%= typeof contactEmail !== 'undefined' ? contactEmail : 'turkeysandwich179@outlook.com' %>",
      "url": "https://alanthebagel.com",
      "sameAs": [
        "https://github.com/TheSecondComing123",
        "https://itch.io/profile/alandabagel"
      ]
    }
  </script>

  <link rel="stylesheet" href="/css/site.css?v=<%= assetVersion %>" />
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
  <link rel="prefetch" href="/blog" />

  <noscript>
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&family=Manrope:wght@400;600;700&family=Sora:wght@600;700&display=swap"
      rel="stylesheet"
    />
    <style>
      .hero-name, .hero-tagline, .hero-bio, .hero-availability, .hero-now, .hero-contact-row,
      .section-label, .project-item, .project-item-desc,
      .blog-preview-entry {
        opacity: 1 !important;
        visibility: visible !important;
        transform: none !important;
        filter: none !important;
      }
    </style>
  </noscript>

</head>
<body data-asset-version="<%= assetVersion %>">
  <svg aria-hidden="true" style="position:absolute;width:0;height:0"><filter id="grain"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter></svg>
  <main id="app" role="main" aria-label="Portfolio content">
    <%- include('./partials/home') %>
    <%- include('./partials/projects') %>
    <%- include('./partials/blog-preview') %>
  </main>

  <nav class="dockbar" role="navigation" aria-label="Main navigation">
    <a class="nav-button" data-section="home" href="#home" aria-label="Home" aria-current="location" id="btn-home">
      <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"/><path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
    </a>
    <a class="nav-button" data-section="projects" href="#projects" aria-label="Projects" id="btn-projects">
      <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 20V4a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/><rect width="20" height="14" x="2" y="6" rx="2"/></svg>
    </a>
    <a class="nav-button" data-section="blog" href="#blog" aria-label="Blog" id="btn-blog">
      <svg class="icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 21h8"/><path d="M21.174 6.812a1 1 0 0 0-3.986-3.987L3.842 16.174a2 2 0 0 0-.5.83l-1.321 4.352a.5.5 0 0 0 .623.622l4.353-1.32a2 2 0 0 0 .83-.497z"/></svg>
    </a>
  </nav>

  <footer class="site-footer" aria-label="Site footer">
    <p class="site-footer-line">// &copy; <%= new Date().getFullYear() %> alan bagel. keep calm and eat bagels.</p>
  </footer>

  <script src="/js/utils.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/gol.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/lightbox.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/index.js?v=<%= assetVersion %>" defer></script>
</body>
</html>
