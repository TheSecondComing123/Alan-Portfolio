<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= pageTitle %></title>
  <meta name="description" content="<%= metaDescription %>" />
  <meta name="robots" content="index, follow" />
  <meta name="theme-color" content="#1b211b" />
  <% if (typeof canonicalUrl === 'string' && canonicalUrl) { %>
    <link rel="canonical" href="<%= canonicalUrl %>" />
  <% } %>
  <meta property="og:type" content="<%= (typeof ogType === 'string' && ogType) ? ogType : 'website' %>" />
  <meta property="og:title" content="<%= pageTitle %>" />
  <meta property="og:description" content="<%= metaDescription %>" />
  <meta property="og:locale" content="en_US" />
  <% if (typeof ogUrl === 'string' && ogUrl) { %>
    <meta property="og:url" content="<%= ogUrl %>" />
  <% } %>
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= pageTitle %>" />
  <meta name="twitter:description" content="<%= metaDescription %>" />
  <meta property="og:image" content="https://alanthebagel.com/images/og.png" />
  <meta name="twitter:image" content="https://alanthebagel.com/images/og.png" />
  <% if (typeof structuredData !== 'undefined' && Array.isArray(structuredData)) { %>
    <% structuredData.forEach((item) => { %>
      <script type="application/ld+json"<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>><%- JSON.stringify(item) %></script>
    <% }) %>
  <% } %>
  <link rel="stylesheet" href="/css/site.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="/css/blog-page.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="/css/vendor/lenis.css?v=<%= assetVersion %>" />
  <link rel="icon" type="image/svg+xml" href="/images/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&family=Manrope:wght@400;600;700&family=Sora:wght@600;700&display=swap" rel="stylesheet" />
  <link rel="prefetch" href="<%= backHref %>" />
  <script src="/js/utils.js?v=<%= assetVersion %>" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/gsap.min.js" defer></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.14.2/dist/ScrollTrigger.min.js" defer></script>
  <script src="/js/vendor/lenis.min.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/lightbox.js?v=<%= assetVersion %>" defer></script>
  <script src="/js/blog.js?v=<%= assetVersion %>" defer></script>
</head>
<body class="blog-page blog-template-<%= contentTemplate %>">
  <svg aria-hidden="true" style="position:absolute;width:0;height:0"><filter id="grain"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/><feColorMatrix type="saturate" values="0"/></filter></svg>

  <main class="blog-page-main" role="main" aria-label="Blog content">
    <section class="blog-section" id="blog">
      <nav class="topnav" aria-label="Site navigation">
        <a href="/">Alan Bagel</a>
        <span class="topnav-sep">/</span>
        <% if (contentTemplate === 'post') { %>
          <a href="/blog">Blog</a>
        <% } else { %>
          <span class="topnav-current">Blog</span>
        <% } %>
      </nav>
      <div class="blog-grid" role="list" aria-label="<%= ariaLabel %>">
        <%- include(contentTemplate, contentData) %>
      </div>
    </section>
  </main>

  <footer class="site-footer" aria-label="Site footer">
    <p class="site-footer-line">// &copy; <%= new Date().getFullYear() %> alan bagel. keep calm and eat bagels.</p>
  </footer>
</body>
</html>
