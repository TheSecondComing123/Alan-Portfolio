<article class="blog-card" role="listitem">
  <header class="blog-header">
    <div class="blog-heading">
      <p class="blog-meta"><%= post.meta %></p>
      <h1 class="blog-title"><%= post.title %></h1>
      <% if (post.tags && post.tags.length > 0) { %>
        <div class="blog-tags" role="list" aria-label="Article topics">
          <% post.tags.forEach((tag) => { %>
            <span class="tag" role="listitem"><%= tag %></span>
          <% }) %>
        </div>
      <% } %>
    </div>
  </header>
  <p class="blog-excerpt"><%= post.excerpt %></p>
  <div class="blog-article blog-markdown"><%- post.renderedMarkdown %></div>
</article>
